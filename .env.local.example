# Supabase Project Reference (found in project settings)
SUPABASE_PROJECT_REF=your-project-ref

# Supabase URL (same as EXPO_PUBLIC_SUPABASE_URL but for CLI/functions)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role Key — NEVER expose to client, only for Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email notifications via Edge Functions)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=notifications@pluvio.app